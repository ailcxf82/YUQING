.page-result{background:#f5f6f9;min-height:100vh;padding-top:180rpx}.page-result__tabs{height:calc(100vh - 180rpx)}.pane-scroll{height:calc(100vh - 180rpx - 100rpx);padding:0 24rpx 32rpx}.pane-section{margin-bottom:32rpx}.pane-title{color:#333;display:block;font-size:30rpx;font-weight:600;margin-bottom:16rpx}.pane-card{background:#fff;border-radius:12rpx;-webkit-box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);padding:24rpx}.pane-text{color:#666;font-size:28rpx;line-height:1.6}.pane-subtabs{background:#fff;border-bottom:1rpx solid #eee;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:16rpx;padding:16rpx 24rpx}.pane-subtab{background:#f5f5f5;border-radius:8rpx;color:#666;font-size:26rpx;padding:12rpx 24rpx}.pane-subtab--active{background:#e6f7ff;color:#1890ff}.pane-stream{padding-top:24rpx}.stream-icon{margin-right:8rpx;vertical-align:middle}.stream-text{white-space:pre-wrap;word-break:break-all}.pane-charts{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:24rpx}.chart-item{background:#fff;border-radius:12rpx;-webkit-box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);padding:24rpx}.chart-label{color:#333;display:block;font-size:28rpx;margin-bottom:12rpx}.chart-note{color:#999;font-size:24rpx;margin-top:8rpx}