.nav-header{background:-webkit-linear-gradient(315deg,#1890ff,#096dd9);background:linear-gradient(135deg,#1890ff,#096dd9);left:0;min-height:88rpx;position:fixed;right:0;top:0;z-index:1000}.nav-header__content{-ms-flex-align:center;-ms-flex-pack:justify;-webkit-align-items:center;align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;justify-content:space-between;padding:0 24rpx}.nav-header__left,.nav-header__right{-ms-flex-align:center;-webkit-align-items:center;align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;width:80rpx}.nav-header__right{-ms-flex-pack:end;-webkit-justify-content:flex-end;justify-content:flex-end}.nav-header__back,.nav-header__settings{-ms-flex-align:center;-ms-flex-pack:center;-webkit-align-items:center;align-items:center;border-radius:50%;display:-webkit-flex;display:-ms-flexbox;display:flex;height:60rpx;-webkit-justify-content:center;justify-content:center;width:60rpx}.nav-header__back .at-icon,.nav-header__settings .at-icon{color:#fff!important}.nav-header__title{color:#fff;-webkit-flex:1;-ms-flex:1;flex:1;font-size:34rpx;font-weight:600;overflow:hidden;text-align:center;text-overflow:ellipsis;white-space:nowrap}