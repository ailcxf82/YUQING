.page-mine{background:#f5f6f9;min-height:100vh;padding-top:180rpx}.page-mine__body{-webkit-box-sizing:border-box;box-sizing:border-box;height:calc(100vh - 180rpx);padding-bottom:32rpx}.page-mine__user{background:-webkit-linear-gradient(315deg,#1890ff,#096dd9);background:linear-gradient(135deg,#1890ff,#096dd9);padding:48rpx 24rpx 40rpx;text-align:center}.page-mine__name{color:#fff;display:block;font-size:36rpx;font-weight:600;margin-top:20rpx}.page-mine__desc{color:hsla(0,0%,100%,.85);display:block;font-size:26rpx;margin-top:8rpx}.page-mine__menu{border-radius:12rpx;-webkit-box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);box-shadow:0 2rpx 12rpx rgba(0,0,0,.06);margin:24rpx;overflow:hidden}